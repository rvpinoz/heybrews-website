generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EDITOR)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id        String   @id @default(cuid())
  slug      String   @unique
  img       String
  date      DateTime
  titleId   String
  titleEn   String
  descId    String
  descEn    String
  tagId     String
  tagEn     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GallerySpan {
  sm
  md
  lg
}

model GalleryItem {
  id          String      @id @default(cuid())
  src         String
  width       Int
  height      Int
  altId       String
  altEn       String
  categoryId  String
  categoryEn  String
  span        GallerySpan @default(sm)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Member {
  id        String   @id @default(cuid())
  handle    String   @unique
  name      String
  img       String
  fid       String
  fen       String
  bioId     String
  bioEn     String
  link      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
